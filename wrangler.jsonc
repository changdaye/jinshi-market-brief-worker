{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jin10-market-brief-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-23",
  "workers_dev": true,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["0 */3 * * *"]
  },
  "kv_namespaces": [
    {
      "binding": "RUNTIME_KV",
      "id": "00000000000000000000000000000000",
      "preview_id": "11111111111111111111111111111111"
    }
  ],
  "d1_databases": [
    {
      "binding": "BRIEF_DB",
      "database_name": "jin10-market-brief",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "DIGEST_INTERVAL_HOURS": "3",
    "HEARTBEAT_INTERVAL_HOURS": "24",
    "REQUEST_TIMEOUT_MS": "15000",
    "FETCH_WINDOW_HOURS": "3",
    "MAX_ITEMS_PER_DIGEST": "60",
    "LLM_MODEL": "gpt-5.4",
    "FAILURE_ALERT_THRESHOLD": "1",
    "FAILURE_ALERT_COOLDOWN_MINUTES": "180"
  }
}
